{
  "name": "ComfyUI-Wan2.2-FreeCraftLog",
  "description": "Wan2.2 video generation template for ComfyUI on RunPod.",
  "image": "ghcr.io/ryoheitanaka/runpod-templates-wan22:v1.0.0-cuda12.4",
  "containerDiskInGb": 200,
  "volumeInGb": 0,
  "ports": [
    "8188/http",
    "22/tcp"
  ],
  "env": {
    "WAN_VARIANT": "t2v_a14b",
    "COMFY_PORT": "8188",
    "HF_HUB_ENABLE_HF_TRANSFER": "1",
    "HF_TOKEN": "your-huggingface-token"
  },
  "startCommand": "/opt/runpod/start.sh"
}
