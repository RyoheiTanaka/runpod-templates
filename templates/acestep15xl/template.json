{
  "name": "ComfyUI-ACE-Step1.5XL-FreeCraftLog",
  "description": "ACE-Step 1.5 XL music generation template for ComfyUI on RunPod.",
  "image": "ghcr.io/ryoheitanaka/runpod-templates-acestep15xl:v1.0.0-cuda12.4",
  "containerDiskInGb": 100,
  "volumeInGb": 0,
  "ports": [
    "8188/http",
    "22/tcp"
  ],
  "env": {
    "ACESTEP_XL_VARIANT": "all",
    "ACESTEP_LM": "all",
    "COMFY_PORT": "8188",
    "HF_HUB_ENABLE_HF_TRANSFER": "1",
    "HF_TOKEN": "your-huggingface-token"
  },
  "startCommand": "/opt/runpod/start.sh"
}
